{
  "hosting": {
    "target": "app",
    "public": "out",
    "cleanUrls": true,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/dashboard/ventas/**", "destination": "/dashboard/ventas/_.html" },
      { "source": "/dashboard/devoluciones/**", "destination": "/dashboard/devoluciones/_.html" },
      { "source": "/dashboard/**", "destination": "/dashboard.html" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|ico|png|svg|woff2)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  }
}
